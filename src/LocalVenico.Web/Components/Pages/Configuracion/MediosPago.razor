@page "/configuracion/medios-pago"
@rendermode InteractiveServer
@using LocalVenico.Web.Data
@using LocalVenico.Web.Data.Entidades
@using LocalVenico.Web.Servicios
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<PageTitle>Medios de Pago — LocalVenico</PageTitle>

@if (!Sesion.EsAdmin) { Nav.NavigateTo("/"); return; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold">Medios de Pago</h2>
    <button class="btn btn-primary" @onclick="AbrirNuevo">+ Nuevo medio</button>
</div>

@if (_cargando)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Calcula vuelto</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mp in _medios)
                    {
                        <tr>
                            <td class="fw-semibold">@mp.Nombre</td>
                            <td>
                                @if (mp.RequiereVuelto)
                                {
                                    <span class="badge bg-info-subtle text-info">Sí (efectivo)</span>
                                }
                                else
                                {
                                    <span class="text-muted small">No</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(mp.Activo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                    @(mp.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => AbrirEditar(mp)">Editar</button>
                                <button class="btn btn-sm @(mp.Activo ? "btn-outline-danger" : "btn-outline-success")"
                                        @onclick="() => ToggleActivo(mp)">
                                    @(mp.Activo ? "Desactivar" : "Activar")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_modalAbierto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") medio de pago</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger py-2">@_error</div> }
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                        <input @bind="_form.Nombre" class="form-control" maxlength="50" placeholder="ej: Transferencia" />
                    </div>
                    <div class="form-check mb-1">
                        <input @bind="_form.RequiereVuelto" class="form-check-input" type="checkbox" id="chkVuelto" />
                        <label class="form-check-label" for="chkVuelto">Calcular vuelto (solo para efectivo)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="Guardar" disabled="@_guardando">
                        @(_guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MedioPago> _medios = [];
    private bool _cargando = true, _modalAbierto = false, _editando = false, _guardando = false;
    private string _error = string.Empty;
    private MedioForm _form = new();
    private int _editandoId;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _medios = await Db.MediosPago.OrderBy(m => m.Nombre).ToListAsync();
        _cargando = false;
    }

    private void AbrirNuevo() { _form = new(); _editando = false; _error = string.Empty; _modalAbierto = true; }

    private void AbrirEditar(MedioPago mp)
    {
        _form = new() { Nombre = mp.Nombre, RequiereVuelto = mp.RequiereVuelto };
        _editandoId = mp.MedioPagoId; _editando = true; _error = string.Empty; _modalAbierto = true;
    }

    private void CerrarModal() => _modalAbierto = false;

    private async Task Guardar()
    {
        _error = string.Empty;
        if (string.IsNullOrWhiteSpace(_form.Nombre)) { _error = "El nombre es obligatorio."; return; }
        _guardando = true;
        if (_editando)
        {
            var mp = await Db.MediosPago.FindAsync(_editandoId);
            if (mp is not null) { mp.Nombre = _form.Nombre.Trim(); mp.RequiereVuelto = _form.RequiereVuelto; }
        }
        else
        {
            Db.MediosPago.Add(new MedioPago { Nombre = _form.Nombre.Trim(), RequiereVuelto = _form.RequiereVuelto });
        }
        try { await Db.SaveChangesAsync(); _modalAbierto = false; await Cargar(); }
        catch { _error = "Error al guardar. El nombre podría estar duplicado."; }
        finally { _guardando = false; }
    }

    private async Task ToggleActivo(MedioPago mp) { mp.Activo = !mp.Activo; await Db.SaveChangesAsync(); }

    private class MedioForm
    {
        public string Nombre { get; set; } = string.Empty;
        public bool RequiereVuelto { get; set; }
    }
}
