@page "/admin/roles"
@rendermode InteractiveServer
@using LocalVenico.Web.Data
@using LocalVenico.Web.Data.Entidades
@using LocalVenico.Web.Servicios
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<PageTitle>Roles — LocalVenico</PageTitle>

@if (!Sesion.EsAdmin) { Nav.NavigateTo("/"); return; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold">Roles del sistema</h2>
    <button class="btn btn-primary" @onclick="AbrirNuevo">+ Nuevo rol</button>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="fw-bold fs-5 text-danger mb-1">admin</div>
                <div class="text-muted small">Acceso total: ventas, inventario, compras, configuración, usuarios.</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="fw-bold fs-5 text-primary mb-1">cajero</div>
                <div class="text-muted small">Punto de venta e inventario básico. No puede configurar el sistema.</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="fw-bold fs-5 text-success mb-1">bodeguero</div>
                <div class="text-muted small">Inventario, ajuste de stock y recepción de mercadería.</div>
            </div>
        </div>
    </div>
</div>

@if (_cargando)
{
    <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Rol</th>
                        <th>Descripción</th>
                        <th>Usuarios</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rol in _roles)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold lv-rol-badge lv-rol-@rol.Nombre">@rol.Nombre</span>
                            </td>
                            <td class="text-muted small">@(rol.Descripcion ?? "—")</td>
                            <td><span class="badge bg-secondary">@rol.Usuarios.Count(u => u.Activo)</span></td>
                            <td>
                                <span class="badge @(rol.Activo ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                    @(rol.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                @if (rol.Nombre != "admin")
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => AbrirEditar(rol)">Editar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_modalAbierto)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editando ? "Editar" : "Nuevo") rol</h5>
                    <button class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-2">@_error</div>
                    }
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                        <input @bind="_form.Nombre" class="form-control" maxlength="50" disabled="@_editando" />
                    </div>
                    <div class="mb-1">
                        <label class="form-label fw-semibold">Descripción</label>
                        <input @bind="_form.Descripcion" class="form-control" maxlength="200" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="Guardar" disabled="@_guardando">
                        @(_guardando ? "Guardando..." : "Guardar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .lv-rol-badge { padding: 2px 10px; border-radius: 4px; font-size: 13px; }
    .lv-rol-admin     { background: #fee2e2; color: #dc2626; }
    .lv-rol-cajero    { background: #dbeafe; color: #1d4ed8; }
    .lv-rol-bodeguero { background: #dcfce7; color: #15803d; }
</style>

@code {
    private List<Rol> _roles = [];
    private bool _cargando = true;
    private bool _modalAbierto = false;
    private bool _editando = false;
    private bool _guardando = false;
    private string _error = string.Empty;
    private RolForm _form = new();
    private int _editandoId;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        _roles = await Db.Roles.Include(r => r.Usuarios).OrderBy(r => r.Nombre).ToListAsync();
        _cargando = false;
    }

    private void AbrirNuevo() { _form = new(); _editando = false; _error = string.Empty; _modalAbierto = true; }

    private void AbrirEditar(Rol rol)
    {
        _form = new() { Nombre = rol.Nombre, Descripcion = rol.Descripcion };
        _editandoId = rol.RolId;
        _editando = true;
        _error = string.Empty;
        _modalAbierto = true;
    }

    private void CerrarModal() => _modalAbierto = false;

    private async Task Guardar()
    {
        _error = string.Empty;
        if (string.IsNullOrWhiteSpace(_form.Nombre)) { _error = "El nombre es obligatorio."; return; }
        _guardando = true;

        if (_editando)
        {
            var rol = await Db.Roles.FindAsync(_editandoId);
            if (rol is not null) { rol.Descripcion = _form.Descripcion; }
        }
        else
        {
            Db.Roles.Add(new Rol { Nombre = _form.Nombre.Trim().ToLower(), Descripcion = _form.Descripcion });
        }

        try { await Db.SaveChangesAsync(); _modalAbierto = false; await Cargar(); }
        catch { _error = "Error al guardar. Verifique que el nombre no esté repetido."; }
        finally { _guardando = false; }
    }

    private class RolForm
    {
        public string Nombre { get; set; } = string.Empty;
        public string? Descripcion { get; set; }
    }
}
