@page "/venta/cierre-caja"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject SesionUsuario Sesion
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Cierre de Caja — LocalVenico</PageTitle>
@if (!Sesion.EsCajero) { Nav.NavigateTo("/login"); return; }

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2 class="mb-0 fw-bold">Cierre de Caja</h2>
        <p class="text-muted mb-0">Resumen de ventas del día: @DateTime.Today.ToString("dddd d 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-CL"))</p>
    </div>
    <button class="btn btn-outline-secondary" @onclick="Imprimir">🖨 Imprimir</button>
</div>

@if (_cargando)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div id="cierre-print">
        <!-- Resumen principal -->
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="display-6 fw-bold text-success">$@_totalVentas.ToString("N0")</div>
                    <div class="text-muted small mt-1">Total vendido</div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="display-6 fw-bold">@_totalTransacciones</div>
                    <div class="text-muted small mt-1">Transacciones</div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="display-6 fw-bold text-info">$@_totalNeto.ToString("N0")</div>
                    <div class="text-muted small mt-1">Neto (sin IVA)</div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="display-6 fw-bold text-warning">$@_totalIva.ToString("N0")</div>
                    <div class="text-muted small mt-1">IVA recaudado</div>
                </div>
            </div>
        </div>

        <!-- Por medio de pago -->
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Por medio de pago</h6>
                        @if (_porMedioPago.Any())
                        {
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Medio</th><th class="text-end">Transacciones</th><th class="text-end">Total</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var mp in _porMedioPago)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@mp.Nombre</td>
                                            <td class="text-end">@mp.Cantidad</td>
                                            <td class="text-end fw-bold">$@mp.Total.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else { <p class="text-muted mb-0">Sin ventas.</p> }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3">Top 5 productos vendidos</h6>
                        @if (_topProductos.Any())
                        {
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Producto</th><th class="text-end">Unidades</th><th class="text-end">Total</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in _topProductos)
                                    {
                                        <tr>
                                            <td class="small">@p.Nombre</td>
                                            <td class="text-end">@p.Unidades.ToString("G29")</td>
                                            <td class="text-end">$@p.Total.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else { <p class="text-muted mb-0">Sin datos.</p> }
                    </div>
                </div>
            </div>
        </div>

        <!-- Listado de boletas -->
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Boletas del día (@_ventas.Count)</h6>
                @if (_ventas.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm small mb-0">
                            <thead class="table-light">
                                <tr><th>N° Boleta</th><th>Hora</th><th>Cajero</th><th>Medio pago</th><th class="text-end">Total</th><th>Estado</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var v in _ventas)
                                {
                                    <tr class="@(v.Estado == "ANULADA" ? "text-muted text-decoration-line-through" : "")">
                                        <td>#@v.NumeroBoleta</td>
                                        <td>@v.FechaVenta.ToString("HH:mm")</td>
                                        <td>@v.Usuario?.NombreCompleto</td>
                                        <td>@v.MedioPago?.Nombre</td>
                                        <td class="text-end">$@v.Total.ToString("N0")</td>
                                        <td><span class="badge @(v.Estado == "ANULADA" ? "bg-danger" : "bg-success")">@v.Estado</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else { <p class="text-muted mb-0">Sin ventas hoy.</p> }
            </div>
        </div>
    </div>
}

@code {
    private bool _cargando = true;
    private decimal _totalVentas, _totalNeto, _totalIva;
    private int _totalTransacciones;
    private List<Venta> _ventas = [];
    private List<(string Nombre, int Cantidad, decimal Total)> _porMedioPago = [];
    private List<(string Nombre, decimal Unidades, decimal Total)> _topProductos = [];

    protected override async Task OnInitializedAsync()
    {
        _ventas = await Db.Ventas
            .Include(v => v.MedioPago)
            .Include(v => v.Usuario)
            .Include(v => v.Detalles)
            .Where(v => v.FechaVenta.Date == DateTime.Today)
            .OrderByDescending(v => v.NumeroBoleta)
            .ToListAsync();

        var activas = _ventas.Where(v => v.Estado != "ANULADA").ToList();
        _totalVentas        = activas.Sum(v => v.Total);
        _totalNeto          = activas.Sum(v => v.SubtotalNeto);
        _totalIva           = activas.Sum(v => v.MontoIva);
        _totalTransacciones = activas.Count;

        _porMedioPago = activas
            .GroupBy(v => v.MedioPago?.Nombre ?? "N/A")
            .Select(g => (g.Key, g.Count(), g.Sum(v => v.Total)))
            .OrderByDescending(x => x.Item3)
            .ToList();

        _topProductos = activas
            .SelectMany(v => v.Detalles)
            .GroupBy(d => d.NombreProducto)
            .Select(g => (g.Key, g.Sum(d => d.Cantidad), g.Sum(d => d.Subtotal)))
            .OrderByDescending(x => x.Item3)
            .Take(5)
            .ToList();

        _cargando = false;
    }

    private async Task Imprimir() => await JS.InvokeVoidAsync("eval", "window.print()");
}
