<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["LocalVenico.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        window.escanerCamara = {
            stream: null,
            nativeDetector: null,
            animFrameId: null,
            html5Scanner: null,
            lastCode: null,
            lastTime: 0,

            start: function (dotnetRef, elementId) {
                var self = this;
                this.stop();
                this.lastCode = null;
                this.lastTime = 0;

                if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                    dotnetRef.invokeMethodAsync('OnCameraError', 'Cámara no disponible. Usa HTTPS (puerto 5001) para acceder con cámara.');
                    return;
                }

                // Intentar API nativa BarcodeDetector (Chrome Android — misma que usa Google)
                if ('BarcodeDetector' in window) {
                    self.startNative(dotnetRef, elementId);
                } else {
                    self.startFallback(dotnetRef, elementId);
                }
            },

            // ── Modo nativo: BarcodeDetector API (rápido, usa el motor de Google) ──
            startNative: function (dotnetRef, elementId) {
                var self = this;
                var container = document.getElementById(elementId);
                container.innerHTML = '';
                var video = document.createElement('video');
                video.setAttribute('playsinline', '');
                video.setAttribute('autoplay', '');
                video.style.width = '100%';
                video.style.display = 'block';
                video.style.borderRadius = '8px';
                container.appendChild(video);

                self.nativeDetector = new BarcodeDetector({
                    formats: ['ean_13', 'ean_8', 'upc_a', 'upc_e', 'code_128', 'code_39', 'itf', 'qr_code']
                });

                navigator.mediaDevices.getUserMedia({
                    video: {
                        facingMode: 'environment',
                        width: { ideal: 1920 },
                        height: { ideal: 1080 },
                        focusMode: { ideal: 'continuous' },
                        zoom: { ideal: 2 }
                    }
                }).then(function (stream) {
                    self.stream = stream;
                    video.srcObject = stream;
                    video.play();

                    // Activar autofoco continuo y torch si está disponible
                    var track = stream.getVideoTracks()[0];
                    var caps = track.getCapabilities ? track.getCapabilities() : {};
                    var constraints = {};
                    if (caps.focusMode && caps.focusMode.includes('continuous')) {
                        constraints.focusMode = 'continuous';
                    }
                    if (Object.keys(constraints).length > 0) {
                        track.applyConstraints({ advanced: [constraints] }).catch(function(){});
                    }

                    function scan() {
                        if (!self.stream) return;
                        self.nativeDetector.detect(video).then(function (barcodes) {
                            if (barcodes.length > 0) {
                                var code = barcodes[0].rawValue;
                                var now = Date.now();
                                if (code !== self.lastCode || (now - self.lastTime) > 3000) {
                                    self.lastCode = code;
                                    self.lastTime = now;
                                    dotnetRef.invokeMethodAsync('OnCameraCodeScanned', code);
                                }
                            }
                        }).catch(function () { });
                        self.animFrameId = requestAnimationFrame(scan);
                    }
                    video.onloadedmetadata = function () { scan(); };
                }).catch(function (err) {
                    self.handleError(err, dotnetRef);
                });
            },

            // ── Modo fallback: html5-qrcode (iOS, navegadores sin BarcodeDetector) ──
            startFallback: function (dotnetRef, elementId) {
                var self = this;
                this.html5Scanner = new Html5Qrcode(elementId);
                this.html5Scanner.start(
                    { facingMode: 'environment' },
                    {
                        fps: 15,
                        qrbox: { width: 280, height: 140 },
                        aspectRatio: 1.5,
                        videoConstraints: {
                            facingMode: 'environment',
                            width: { ideal: 1920 },
                            height: { ideal: 1080 },
                            advanced: [{ focusMode: 'continuous' }]
                        }
                    },
                    function (code) {
                        var now = Date.now();
                        if (code === self.lastCode && (now - self.lastTime) < 3000) return;
                        self.lastCode = code;
                        self.lastTime = now;
                        dotnetRef.invokeMethodAsync('OnCameraCodeScanned', code);
                    },
                    function () { }
                ).catch(function (err) {
                    self.handleError(err, dotnetRef);
                });
            },

            handleError: function (err, dotnetRef) {
                var msg = 'No se pudo abrir la cámara.';
                var errStr = err.toString();
                if (errStr.indexOf('NotAllowedError') >= 0) msg = 'Permiso de cámara denegado. Permite el acceso en tu navegador.';
                else if (errStr.indexOf('NotFoundError') >= 0) msg = 'No se encontró una cámara en este dispositivo.';
                else if (errStr.indexOf('insecure') >= 0 || errStr.indexOf('secure') >= 0) msg = 'Cámara requiere HTTPS. Accede por https://' + location.hostname + ':5001';
                dotnetRef.invokeMethodAsync('OnCameraError', msg);
            },

            stop: function () {
                if (this.animFrameId) {
                    cancelAnimationFrame(this.animFrameId);
                    this.animFrameId = null;
                }
                if (this.stream) {
                    this.stream.getTracks().forEach(function (t) { t.stop(); });
                    this.stream = null;
                }
                this.nativeDetector = null;
                if (this.html5Scanner) {
                    try { this.html5Scanner.stop(); } catch (e) { }
                    try { this.html5Scanner.clear(); } catch (e) { }
                    this.html5Scanner = null;
                }
            }
        };
    </script>
</body>

</html>
